# ── mango runtime path ────────────────────────────────────────────────────────
# Base directory for all mango files: config, socket, agent memory, agents/, skills/
# Defaults to ~/.mango when unset.
MANGO_DIR=~/.mango

# ── LLM providers ─────────────────────────────────────────────────────────────
# Reference these in config.yaml as: api_key: "${ANTHROPIC_API_KEY}"
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Discord bot ───────────────────────────────────────────────────────────────
# Reference in config.yaml as: token: "${DISCORD_TOKEN}"
DISCORD_TOKEN=
